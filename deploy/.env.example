# Published by .github/workflows/server-container.yml.
WISP_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/wisp-science-server:latest

# Credential configured in Qingxiaoda. Generate a long random value.
WISP_SERVER_API_KEY=replace-with-a-long-random-service-token

# Server-side OpenAI-compatible model configuration used until Qingxiaoda
# provides a stable, trustworthy per-user identifier for BYOK.
WISP_API_URL=https://api.deepseek.com
WISP_API_KEY=replace-with-provider-api-key
WISP_MODEL=deepseek-chat
WISP_PUBLIC_MODEL=wisp-science-v1

# Required by NCBI-backed PubMed, ClinVar, and dbSNP tools so NCBI can
# contact the service operator before blocking abusive traffic.
WISP_NCBI_EMAIL=replace-with-your-email@example.com
# Optional: raises the NCBI E-utilities rate limit. Leave unset if unused.
# WISP_NCBI_API_KEY=replace-with-ncbi-api-key

# Resource and cost limits for the 1 GiB host.
WISP_MAX_CONCURRENT=1
WISP_MAX_ITER=12
WISP_MAX_OUTPUT_TOKENS=4096
WISP_MAX_TOOL_CALLS=12
WISP_MAX_TOOL_RESULT_CHARS=24000
WISP_MAX_INPUT_CHARS=200000
WISP_DAILY_TOKEN_LIMIT=250000
WISP_REQUEST_TIMEOUT_SECS=110
WISP_TOOL_TIMEOUT_SECS=60

# Used by Caddy for certificate expiry notices.
ACME_EMAIL=replace-with-your-email@example.com

RUST_LOG=wisp_server=info
